# hugo-mcp-go environment example
#
# Review-only template. Do not place real secrets here.

# Base roots
HUGO_ROOT=/var/lib/hugo-mcp-go
HUGO_CONTENT_ROOT=/var/lib/hugo-mcp-go/content
HUGO_STATIC_ROOT=/var/lib/hugo-mcp-go/static

# Optional request / tool / content limits
HUGO_MAX_REQUEST_BYTES=1048576
HUGO_MAX_TOOL_ARGS_BYTES=262144
HUGO_MAX_PAGE_BYTES=1048576
HUGO_MAX_ASSET_BYTES=26214400
HUGO_MAX_LIST_PAGES=500
HUGO_MAX_LIST_ASSETS=500

# Binary contract
# Recommended absolute path for production approval.
HUGO_EXPECTED_HUGO_BIN=/usr/local/bin/hugo
# Optional version prefix used by deploy/preflight.sh.
# Example: Hugo v0.150.
HUGO_EXPECTED_HUGO_VERSION_PREFIX=

# Deployment identity contract
HUGO_SERVICE_USER=hugo-mcp
HUGO_SERVICE_GROUP=hugo-mcp

# Optional PATH contract for operators who keep PATH lookup behavior.
PATH=/usr/local/bin:/usr/bin:/bin
